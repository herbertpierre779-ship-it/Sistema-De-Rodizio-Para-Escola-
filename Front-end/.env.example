# Deixe vazio para usar o proxy local do Vite em desenvolvimento.
VITE_API_URL=

# Opcional para acessar direto o backend por IP em outro ambiente:
# VITE_API_URL=http://192.168.0.10:8000

# Opcional para trocar o destino do proxy do Vite:
# VITE_PROXY_TARGET=http://127.0.0.1:8000

# Feedback de áudio e voz do sistema:
VITE_FEEDBACK_SOUND_ENABLED=true
VITE_FEEDBACK_SPEECH_ENABLED=true
